# Add the API keys for the providers you want to use.
# Copy this file to .env.local and fill in your key(s).
# You only need the key(s) for the provider(s) you'll select in the UI.

# Gemini 2.5 Flash (cheapest, recommended) — Get key at https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI GPT-4.1 Mini — Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude Haiku 4.5 — Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
